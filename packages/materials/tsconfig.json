{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "lib": ["DOM", "ESNext"],
    "types": ["vue"],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@lowcode/shared": [
        "../shared/dist/index.d.ts"
      ],
      "@lowcode/shared/*": [
        "../shared/dist/*.d.ts"
      ]
    },
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}