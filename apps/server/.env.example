# =============================================================================
# 低代码平台服务器环境变量配置
# =============================================================================
# 注意：这些是示例值，请根据实际环境修改，特别是敏感信息

# =============================================================================
# 数据库配置
# =============================================================================
# MySQL数据库连接URL - 格式: mysql://用户名:密码@主机:端口/数据库名
# 请确保密码足够复杂且不包含特殊字符编码问题
DATABASE_URL="mysql://lowcode_user:YourSecurePassword123!@localhost:3306/lowcode_platform?schema=public&timezone=utc"

# =============================================================================
# JWT认证配置 ⚠️ 重要安全设置
# =============================================================================
# JWT密钥 - 必须至少32个字符，建议使用随机生成的强密钥
# 可以使用以下命令生成: openssl rand -base64 32
# 或者在Node.js中: require('crypto').randomBytes(32).toString('hex')
JWT_SECRET="your-super-secure-jwt-secret-key-at-least-32-chars-long-change-me"

# JWT令牌过期时间 - 支持格式: 60, 60s, 60m, 60h, 7d
JWT_EXPIRES_IN="7d"

# =============================================================================
# 服务器配置
# =============================================================================
# 服务器监听端口
PORT=3001

# 环境标识 - development, production, test
NODE_ENV=development

# =============================================================================
# 安全配置 (可选，根据需要添加)
# =============================================================================
# CORS允许的源 - 生产环境请指定具体域名，用逗号分隔
# CORS_ORIGINS="http://localhost:3000,https://yourdomain.com"

# API请求限制 - 每分钟最大请求数
# RATE_LIMIT_MAX=100

# =============================================================================
# 数据库池配置 (可选)
# =============================================================================
# DATABASE_POOL_MIN=5
# DATABASE_POOL_MAX=20